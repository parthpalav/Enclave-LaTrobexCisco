# ============================================================================
# CrowdVision Heatmap Engine — environment configuration
# Copy to `.env` and adjust. NOTHING is hardcoded in the app; every value here
# has a safe default in app/core/config.py.
# ============================================================================

# ---- Application ----
APP_NAME=CrowdVision Heatmap Engine
ENVIRONMENT=development           # development | staging | production
DEBUG=true
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*                    # comma-separated origins, or * for all

# ---- Database (PostgreSQL, async driver) ----
DATABASE_URL=postgresql+asyncpg://crowdvision:crowdvision@localhost:5432/crowdvision
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=60

# ---- YOLO detection ----
YOLO_MODEL=yolo11n.pt             # YOLOv11 (auto-downloaded on first run)
YOLO_FALLBACK_MODEL=yolov8n.pt    # fallback if primary fails to load
YOLO_DEVICE=auto                  # auto | cpu | cuda | cuda:0 | mps
YOLO_CONFIDENCE=0.30
YOLO_IOU=0.45
YOLO_IMGSZ=640
PERSON_CLASS_ID=0
YOLO_HALF_PRECISION=false         # FP16 on CUDA for throughput

# ---- Tracking ----
TRACKER_CONFIG=bytetrack.yaml     # ByteTrack

# ---- Heatmap / Gaussian density ----
HEATMAP_SIGMA=25.0                # Gaussian spread per person (px)
HEATMAP_KERNEL_SIZE=0             # 0 = derive from sigma
HEATMAP_ALPHA=0.65                # peak overlay opacity (dense areas)
HEATMAP_BASE_ALPHA=0.4            # baseline blue wash everywhere (0 = transparent when empty)
HEATMAP_DOWNSCALE=0.5             # compute density at this fraction (speed)
HEATMAP_MIN_DENSITY=0.05          # below this stays transparent
HEATMAP_COLORMAP=crowdvision      # crowdvision | jet | turbo | inferno | viridis
DENSITY_HIGH_THRESHOLD=0.6        # crowded-zone threshold
HEATMAP_MODE=overlay              # overlay (blend on camera) | pure (grey bg, no faces/visuals)
DENSITY_MODE=foot                 # foot | center | box (box colours the whole person area)
HEATMAP_GRID=false                # draw faint reference grid (pure mode only)
HEATMAP_GRID_SIZE=32              # grid cell size (px)

# ---- Streaming / processing ----
TARGET_FPS=25
FRAME_WIDTH=1280
FRAME_HEIGHT=720
JPEG_QUALITY=80
MAX_CAMERAS=8
ANALYTICS_PERSIST_INTERVAL=25
STORE_RAW_VIDEO=false             # NEVER store raw CCTV unless explicitly true

# ---- Crowd-level classification (by people count) ----
CROWD_MODERATE_THRESHOLD=5        # >= this many people  -> "Moderate"
CROWD_CROWDED_THRESHOLD=10        # >= this many people  -> "Crowded"
CROWD_OVERCROWDED_THRESHOLD=20    # >= this many people  -> "Overcrowded"

# ---- Alerts ----
ALERT_PEOPLE_THRESHOLD=50
ALERT_DENSITY_THRESHOLD=0.75

# ---- Logging ----
LOG_LEVEL=INFO
LOG_JSON=false
